# AtenLana Portal - Environment Template
# Copy to .env and adjust values for local dev.
# For Vercel: set these in Project Settings → Environment Variables

# ====================
# REQUIRED - App won't run without these
# ====================

# PostgreSQL connection string.
# Get free at https://supabase.com or https://neon.tech
# Format: postgresql://USER:PASS@HOST:5432/DBNAME
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Flask session signing + CSRF secret. Generate a long random string.
SECRET_KEY=change-me-to-a-long-random-string

# Production or development
FLASK_ENV=production

# Default admin credentials (seeded when DB is first created)
SUPERADMIN_PASS=change-me-superadmin
ADMIN_PASS=change-me-admin

# ====================
# OPTIONAL - Feature-specific
# ====================

# Flask debug mode (1 = on, 0 = off). Only use in development.
FLASK_DEBUG=0

# Local server binding (default: 0.0.0.0)
HOST=0.0.0.0
PORT=5000

# Force secure cookies even without FLASK_ENV=production
FORCE_SECURE_COOKIES=0

# Upload path (Vercel uses /tmp automatically)
UPLOAD_FOLDER=

# Force sample data purge in UI
PURGE_SAMPLE=0

# ====================
# EMAIL (SMTP) - Attendance receipts & session notifications
# ====================
# Uses Gmail SMTP by default. Use an App Password (not your regular password).
# For Gmail: https://support.google.com/accounts/answer/185833
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ====================
# SOLANA (Helius) - On-chain $ATND tokens, cNFT badges, attendance proof
# ====================
# Get a free Helius API key: https://helius.dev
HELIUS_API_KEY=

# Solana fee payer private key (base58). Fund with ~0.01 SOL for tx fees.
SOLANA_FEE_PAYER=

# $ATND SPL token mint address. Create once via Helius dashboard or script.
ATND_TOKEN_MINT=

# Compressed NFT collection mint address. Create once via Helius dashboard.
BADGE_COLLECTION_MINT=
