# AtendeX Grid Systems - Environment Template
# Copy to .env and adjust values.

# --------------------
# Compulsory (for real deployments)
# --------------------

# PostgreSQL DSN used by the app for all persistence.
# Example (Supabase/Postgres):
# postgresql://USERNAME:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Flask session + CSRF signing secret.
SECRET_KEY=change-me-to-a-long-random-string

# Operational environment.
# Use: production (Vercel) or development (local)
FLASK_ENV=production

# Default credentials for seeded identities (used when the DB is empty).
# They are NOT the admin account username; username is hardcoded by the seeder.
SUPERADMIN_PASS=change-me-superadmin
ADMIN_PASS=change-me-admin

# --------------------
# Optional (but commonly needed)
# --------------------

# If set to 1, enables verbose debug when running via python index.py
FLASK_DEBUG=0

# If set, overrides the host bind for local server.
HOST=0.0.0.0

# If set, overrides the port for local server.
PORT=5000

# If true, forces secure session cookies even without FLASK_ENV=production.
FORCE_SECURE_COOKIES=0

# Upload folder used in production runtime.
# In production, code defaults to /tmp/atendex_uploads.
UPLOAD_FOLDER=

# Role/password seeding (optional CLI-like bootstrap for empty DB)
# When provided and DB has no admin yet, the app will create an admin from these.
SUPERADMIN_SEED_USER=
SUPERADMIN_SEED_PASS=
SUPERADMIN_SEED_NAME=Super

# Security + feature toggles
# security_mode: 'on' enables WAF + IP blocks logic; 'off' disables it.
# website_status: 'on' or 'off' can be updated in DB after init.
# strict_integrity_mode: 'on' enforces ONE STUDENT PER DEVICE + ONE DEVICE PER STUDENT.
# NOTE: these are seeded into the settings table at init_db() if missing.

# If you want to force sample purge capability in UI.
PURGE_SAMPLE=0

# --------------------
# Email (SMTP) - for attendance receipts & session notifications
# --------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --------------------
# Solana (Helius) - for on-chain rewards, tokens & badges
# --------------------
# Get a free API key at https://helius.dev
HELIUS_API_KEY=
# The fee payer private key (base58) - fund with a small amount of SOL
SOLANA_FEE_PAYER=
# $ATND SPL token mint address (create once via Helius dashboard)
ATND_TOKEN_MINT=
# Compressed NFT collection mint address (create once via Helius dashboard)
BADGE_COLLECTION_MINT=

